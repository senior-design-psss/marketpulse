# ===========================================
# Backend Environment Variables
# ===========================================

# Database (local dev uses Docker Compose Postgres)
DATABASE_URL=postgresql+asyncpg://marketpulse:localdev@localhost:5432/marketpulse

# Supabase (for production / realtime features)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-key
SUPABASE_ANON_KEY=your-anon-key

# Redis (local dev uses Docker Compose Redis)
REDIS_URL=redis://localhost:6379

# Anthropic (Claude Haiku for LLM sentiment scoring)
ANTHROPIC_API_KEY=sk-ant-your-key

# Reddit API (asyncpraw)
REDDIT_CLIENT_ID=your-client-id
REDDIT_CLIENT_SECRET=your-client-secret
REDDIT_USERNAME=your-username
REDDIT_PASSWORD=your-password
REDDIT_USER_AGENT=MarketPulseAI/1.0

# App config
ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000

# ===========================================
# Frontend Environment Variables
# ===========================================

NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
